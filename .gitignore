.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# IDE Project settings
.vscode/*
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace

# Global Development Tools
.pre-commit/
.cache/

# ==========================================
# 2. FRONTEND (TypeScript / Vite / Node)
# ==========================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Frontend Execution Logs
frontend/logs/
