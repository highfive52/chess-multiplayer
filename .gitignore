# 3. BACKEND (Python / uv / FastAPI)
# ==========================================
# Python Virtual Environments
backend/.venv/
backend/venv/
backend/env/

# Python Bytecode and Cache Directories
backend/__pycache__/
backend/**/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/.ruff_cache/
backend/.mypy_cache/

# Backend Environment & Secret Files
backend/.env
backend/*.env.local